{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "anvitam.com" }],
      "destination": "https://www.anvitam.com/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "DENY" },
        { "key": "X-XSS-Protection",        "value": "1; mode=block" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",      "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "X-Robots-Tag",            "value": "index, follow" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://platform.twitter.com https://cdn.tailwindcss.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; frame-src https://www.youtube.com; connect-src 'self' https://generativelanguage.googleapis.com;"
        }
      ]
    }
  ],
  "functions": {
    "api/ssr-seo.ts": {
      "includeFiles": "dist/index.html"
    }
  },
  "rewrites": [
    { "source": "/api/admin/:path*", "destination": "/api/admin.ts" },
    { "source": "/api/db-init", "destination": "/api/admin.ts" },
    { "source": "/api/blogs", "destination": "/api/blogs.ts" },
    { "source": "/api/blogs/:id", "destination": "/api/blogs.ts" },
    { "source": "/api/products", "destination": "/api/products.ts" },
    { "source": "/api/products/:id", "destination": "/api/products.ts" },
    { "source": "/api/projects", "destination": "/api/projects.ts" },
    { "source": "/api/projects/:id", "destination": "/api/projects.ts" },
    { "source": "/api/services", "destination": "/api/services.ts" },
    { "source": "/api/services/:id", "destination": "/api/services.ts" },
    { "source": "/api/messages", "destination": "/api/messages.ts" },
    { "source": "/api/messages/:id", "destination": "/api/messages.ts" },
    { "source": "/api/testimonials", "destination": "/api/testimonials.ts" },
    { "source": "/api/testimonials/:id", "destination": "/api/testimonials.ts" },
    { "source": "/api/analytics", "destination": "/api/analytics.ts" },
    { "source": "/api/indexnow", "destination": "/api/indexnow.ts" },
    { "source": "/:key([a-zA-Z0-9_-]{8,128})\\.txt", "destination": "/api/indexnow-key?key=:key" },
    { "source": "/((?!api/|.*\\.[a-zA-Z0-9]+$).*)", "destination": "/api/ssr-seo?path=/$1" }
  ]
}
