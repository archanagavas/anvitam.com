# ── REQUIRED: Set in Vercel Dashboard → Project → Settings → Environment Variables ──
# These are server-side only — never exposed to the browser.

# Neon PostgreSQL connection string (from https://console.neon.tech)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Admin login credentials (server-side bcrypt comparison)
ADMIN_EMAIL=ar.archanagavas@gmail.com
ADMIN_PASSWORD_HASH=   # bcrypt hash — run: node -e "require('bcryptjs').hash('yourpassword',12).then(console.log)"

# JWT signing secret (64+ random chars)
JWT_SECRET=   # run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# DB init secret (one-time use, any random string)
ADMIN_INIT_SECRET=   # any random string — used to call /api/db-init?secret=...

# Gemini AI API key (from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# ── OPTIONAL ──────────────────────────────────────────────────────────────
# Formspree ID for contact form email delivery (from https://formspree.io)
VITE_FORMSPREE_ID=
